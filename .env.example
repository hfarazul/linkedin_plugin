# Choose ONE backend: playwright or unipile
LINKEDIN_BACKEND=playwright

# --- Playwright backend ---
# After logging into LinkedIn once via `python -m linkedin_agent auth`,
# session state is stored at playwright_state/state.json. Nothing else needed.

# --- Unipile backend ---
# Sign up at unipile.com, connect your LinkedIn account, grab the API key + account ID.
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
UNIPILE_DSN=api.unipile.com:13xxx

# --- Safety / rate limits (per 24h rolling window) ---
DAILY_MAX_REACTIONS=30
DAILY_MAX_CONNECTIONS=20
DAILY_MAX_DMS=10
DAILY_MAX_SEARCHES=50

# Min/max delay between actions, seconds. Randomized within range.
ACTION_DELAY_MIN=30
ACTION_DELAY_MAX=90

# DRY_RUN=1 means tools log intent but never call LinkedIn.
DRY_RUN=0
